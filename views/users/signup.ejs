<% layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <h1 class="col-6 offset-3">SignUp</h1>
    <div class="col-6 offset-3 mt-2">
        <form action="/signup" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <lable for="username" class="form-label">Username</lable>
                <input 
                name="username"
                type="text"
                class="form-control"
                required>
                  <div class="invalid-feedback">Please enter the username!</div>
            </div>
           
            <div class="mb-3">
                <lable for="password" class="form-label">Password</lable>
                <input 
                name="password"
                type="password"
                class="form-control"
                required>
                 <div class="invalid-feedback">Please enter the password!</div>
            </div>
            
            <button class="btn btn-success">SignUp</button>
        </form>
    </div>
</div>